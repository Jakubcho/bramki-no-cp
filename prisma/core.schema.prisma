generator client {
  provider = "prisma-client-js"
  output   = "../generated/core"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL_CONFIG")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now())
}

model Event {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?
  qrPrefixes String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  externalDirectoryID Int?

  version     Int      @default(1)

  startDate   DateTime?
  endDate     DateTime?
  entrances   String[]
  imageUrl  String?

  steps     Step[]

  ticketRules     Json?     @default("{}")

  partitions EventPartition[]
  weeks     EventWeek[] @relation("EventWeekEvents")
}
  model UserHost {
    id        String   @id @default(cuid())
    fullName String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    qrCodeUrl   String?

    @@index([fullName])
  }
  model EventPartition {
    id            String   @id @default(cuid())

    eventId       String
    event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

    partitionSlug String

    createdAt     DateTime @default(now())

    @@unique([eventId, partitionSlug])
  }

model EventTemplate {
  id        String   @id @default(cuid())
  name      String
  structure Json
  createdAt DateTime @default(now())
}

model Step {
  id           String            @id @default(cuid())
  eventId      String
  order        Int
  type         StepType
  createdAt    DateTime          @default(now())
  options      Option[]
  event        Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  translations StepTranslation[]
}

model StepTranslation {
  id     String @id @default(cuid())
  stepId String
  locale String
  title  String
  step   Step   @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([stepId, locale])
}

model Option {
  id           String              @id @default(cuid())
  stepId       String
  value        String
  iconUrl      String?
  order        Int
  createdAt    DateTime            @default(now())
  step         Step                @relation(fields: [stepId], references: [id], onDelete: Cascade)
  translations OptionTranslation[]
}

model OptionTranslation {
  id       String @id @default(cuid())
  optionId String
  locale   String
  label    String
  option   Option @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, locale])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  userRole  String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}

model EventWeek {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events    Event[]  @relation("EventWeekEvents")
}

model ShortLink {
  id          String   @id @default(cuid())
  code        String   @unique // np. "ad"
  destination String   // np. "/aktywacja/warsawpack_2026"
  description String?  // Notatka dla Ciebie, np. "Kioski wejście A"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


enum Role {
  ADMIN
  EDITOR
}

enum StepType {
  SINGLE_CHOICE
  MULTI_CHOICE
  MULTI_CHOICE_ICON
  FORM
  CONSENT
}
