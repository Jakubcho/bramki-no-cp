generator client {
  provider = "prisma-client-js"
  output   = "../generated/activation"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_ACTIVATION")
}

model ActivationEntry {
  id               String   @id @default(cuid())
  slug             String
  entryId          String
  qrCode           String?

  email            String?
  phone            String?
  fullName         String?
  streetAddress    String?
  houseNumber      String?
  apartmentNumber  String?
  postalCode       String?
  city             String?
  country          String?

  domain           String?
  badge            String?
  fairYear         String?
  fairDate         String?

  createdAt        DateTime @default(now())

  @@unique([slug, entryId])
  @@index([slug])
}